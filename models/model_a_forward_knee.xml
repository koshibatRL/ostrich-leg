<mujoco model="forward_knee_biped">
  <!-- ============================================================
       MODEL A: Conventional Forward-Knee Bipedal Platform
       - Standard human-like knee (bends forward)
       - 6 actuators per leg (hip 3DOF + knee 1DOF + ankle 2DOF)
       - Total: 12 actuators
       - Designed as baseline for efficiency comparison
       ============================================================ -->

  <compiler angle="degree" inertiafromgeom="true"/>

  <option timestep="0.002" integrator="RK4" gravity="0 0 -9.81">
    <flag warmstart="enable"/>
  </option>

  <default>
    <joint limited="true" damping="0.5" armature="0.01"/>
    <geom contype="1" conaffinity="1" condim="3" friction="1.0 0.005 0.0001"
          density="1000" margin="0.001"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5" texuniform="true" reflectance="0.2"/>
    <material name="body_mat" rgba="0.7 0.7 0.7 1"/>
    <material name="joint_mat" rgba="0.2 0.6 0.8 1"/>
    <material name="foot_mat" rgba="0.4 0.4 0.4 1"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="50 50 0.1" material="groundplane"/>

    <!-- ======== TORSO (payload platform) ======== -->
    <body name="torso" pos="0 0 0.85">
      <freejoint name="root"/>
      <geom name="torso_geom" type="box" size="0.15 0.1 0.1" mass="10.0" material="body_mat"/>

      <!-- IMU sensor site -->
      <site name="imu_site" pos="0 0 0" size="0.01"/>

      <!-- Payload mount point -->
      <site name="payload_mount" pos="0 0 0.1" size="0.02" rgba="1 0 0 0.5"/>

      <!-- ======== RIGHT LEG ======== -->
      <body name="r_hip_yaw_link" pos="0 -0.1 0">
        <joint name="r_hip_yaw" type="hinge" axis="0 0 1" range="-45 45"
               damping="2.0" stiffness="0"/>
        <geom type="sphere" size="0.04" material="joint_mat"/>

        <body name="r_hip_roll_link" pos="0 0 0">
          <joint name="r_hip_roll" type="hinge" axis="1 0 0" range="-30 30"
                 damping="2.0"/>
          <geom type="sphere" size="0.035" material="joint_mat"/>

          <body name="r_hip_pitch_link" pos="0 0 0">
            <joint name="r_hip_pitch" type="hinge" axis="0 1 0" range="-60 60"
                   damping="2.0"/>
            <geom type="sphere" size="0.035" material="joint_mat"/>

            <!-- Upper leg (thigh) -->
            <body name="r_thigh" pos="0 0 -0.02">
              <geom name="r_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.3"
                    size="0.04" mass="3.0" material="body_mat"/>

              <!-- KNEE: Forward bending (conventional) -->
              <body name="r_knee_link" pos="0 0 -0.3">
                <joint name="r_knee" type="hinge" axis="0 1 0" range="0 120"
                       damping="1.5"/>
                <geom type="sphere" size="0.035" material="joint_mat"/>

                <!-- Lower leg (shin) -->
                <body name="r_shin" pos="0 0 -0.02">
                  <geom name="r_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.28"
                        size="0.035" mass="2.0" material="body_mat"/>

                  <!-- ANKLE -->
                  <body name="r_ankle_link" pos="0 0 -0.28">
                    <joint name="r_ankle_pitch" type="hinge" axis="0 1 0" range="-30 45"
                           damping="1.0"/>
                    <geom type="sphere" size="0.03" material="joint_mat"/>

                    <body name="r_ankle_roll_link" pos="0 0 0">
                      <joint name="r_ankle_roll" type="hinge" axis="1 0 0" range="-20 20"
                             damping="1.0"/>

                      <!-- Foot -->
                      <body name="r_foot" pos="0 0 -0.02">
                        <geom name="r_foot_geom" type="box" size="0.1 0.05 0.015"
                              pos="0.02 0 0" mass="0.5" material="foot_mat"/>
                        <!-- Contact sensors -->
                        <site name="r_heel" pos="-0.06 0 -0.015" size="0.01"/>
                        <site name="r_toe" pos="0.08 0 -0.015" size="0.01"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- ======== LEFT LEG (mirror of right) ======== -->
      <body name="l_hip_yaw_link" pos="0 0.1 0">
        <joint name="l_hip_yaw" type="hinge" axis="0 0 1" range="-45 45"
               damping="2.0"/>
        <geom type="sphere" size="0.04" material="joint_mat"/>

        <body name="l_hip_roll_link" pos="0 0 0">
          <joint name="l_hip_roll" type="hinge" axis="1 0 0" range="-30 30"
                 damping="2.0"/>
          <geom type="sphere" size="0.035" material="joint_mat"/>

          <body name="l_hip_pitch_link" pos="0 0 0">
            <joint name="l_hip_pitch" type="hinge" axis="0 1 0" range="-60 60"
                   damping="2.0"/>
            <geom type="sphere" size="0.035" material="joint_mat"/>

            <body name="l_thigh" pos="0 0 -0.02">
              <geom name="l_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.3"
                    size="0.04" mass="3.0" material="body_mat"/>

              <body name="l_knee_link" pos="0 0 -0.3">
                <joint name="l_knee" type="hinge" axis="0 1 0" range="0 120"
                       damping="1.5"/>
                <geom type="sphere" size="0.035" material="joint_mat"/>

                <body name="l_shin" pos="0 0 -0.02">
                  <geom name="l_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.28"
                        size="0.035" mass="2.0" material="body_mat"/>

                  <body name="l_ankle_link" pos="0 0 -0.28">
                    <joint name="l_ankle_pitch" type="hinge" axis="0 1 0" range="-30 45"
                           damping="1.0"/>
                    <geom type="sphere" size="0.03" material="joint_mat"/>

                    <body name="l_ankle_roll_link" pos="0 0 0">
                      <joint name="l_ankle_roll" type="hinge" axis="1 0 0" range="-20 20"
                             damping="1.0"/>

                      <body name="l_foot" pos="0 0 -0.02">
                        <geom name="l_foot_geom" type="box" size="0.1 0.05 0.015"
                              pos="0.02 0 0" mass="0.5" material="foot_mat"/>
                        <site name="l_heel" pos="-0.06 0 -0.015" size="0.01"/>
                        <site name="l_toe" pos="0.08 0 -0.015" size="0.01"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- ======== ACTUATORS (12 total: 6 per leg) ======== -->
  <actuator>
    <!-- Right leg -->
    <motor name="r_hip_yaw_act"   joint="r_hip_yaw"      gear="80"  ctrlrange="-1 1"/>
    <motor name="r_hip_roll_act"  joint="r_hip_roll"     gear="80"  ctrlrange="-1 1"/>
    <motor name="r_hip_pitch_act" joint="r_hip_pitch"    gear="120" ctrlrange="-1 1"/>
    <motor name="r_knee_act"      joint="r_knee"         gear="120" ctrlrange="-1 1"/>
    <motor name="r_ankle_pitch_act" joint="r_ankle_pitch" gear="60" ctrlrange="-1 1"/>
    <motor name="r_ankle_roll_act"  joint="r_ankle_roll"  gear="40" ctrlrange="-1 1"/>
    <!-- Left leg -->
    <motor name="l_hip_yaw_act"   joint="l_hip_yaw"      gear="80"  ctrlrange="-1 1"/>
    <motor name="l_hip_roll_act"  joint="l_hip_roll"     gear="80"  ctrlrange="-1 1"/>
    <motor name="l_hip_pitch_act" joint="l_hip_pitch"    gear="120" ctrlrange="-1 1"/>
    <motor name="l_knee_act"      joint="l_knee"         gear="120" ctrlrange="-1 1"/>
    <motor name="l_ankle_pitch_act" joint="l_ankle_pitch" gear="60" ctrlrange="-1 1"/>
    <motor name="l_ankle_roll_act"  joint="l_ankle_roll"  gear="40" ctrlrange="-1 1"/>
  </actuator>

  <!-- ======== SENSORS ======== -->
  <sensor>
    <accelerometer name="imu_acc" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
    <framequat name="torso_quat" objtype="site" objname="imu_site"/>
    <touch name="r_heel_touch" site="r_heel"/>
    <touch name="r_toe_touch" site="r_toe"/>
    <touch name="l_heel_touch" site="l_heel"/>
    <touch name="l_toe_touch" site="l_toe"/>
  </sensor>
</mujoco>
