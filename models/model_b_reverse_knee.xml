<mujoco model="reverse_knee_biped">
  <!-- ============================================================
       MODEL B: Reverse-Knee (Ostrich-type) Bipedal Platform
       - Knee bends backward (digitigrade / ostrich-like)
       - NO knee motor — replaced by spring + joint limits (tensegrity analog)
       - Toe spring for elastic energy storage (SEA, per Rubenson 2011)
       - Mass concentrated proximally (closer to hip)
       - Total actuators: 10 (5 per leg, vs 6 for Model A)
       ============================================================ -->

  <compiler angle="degree" inertiafromgeom="true"/>

  <option timestep="0.002" integrator="RK4" gravity="0 0 -9.81">
    <flag warmstart="enable"/>
  </option>

  <default>
    <joint limited="true" damping="0.5" armature="0.01"/>
    <geom contype="1" conaffinity="1" condim="3" friction="1.0 0.005 0.0001"
          density="1000" margin="0.001"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5" texuniform="true" reflectance="0.2"/>
    <material name="body_mat" rgba="0.9 0.5 0.2 1"/>
    <material name="joint_mat" rgba="0.8 0.3 0.1 1"/>
    <material name="foot_mat" rgba="0.5 0.3 0.1 1"/>
    <material name="spring_mat" rgba="0.2 0.8 0.3 1"/>
  </asset>

  <worldbody>
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2" pos="0 0 4" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="50 50 0.1" material="groundplane"/>

    <!-- ======== TORSO (payload platform) — same mass as Model A ======== -->
    <body name="torso" pos="0 0 0.85">
      <freejoint name="root"/>
      <geom name="torso_geom" type="box" size="0.15 0.1 0.1" mass="10.0" material="body_mat"/>

      <site name="imu_site" pos="0 0 0" size="0.01"/>
      <site name="payload_mount" pos="0 0 0.1" size="0.02" rgba="1 0 0 0.5"/>

      <!-- ======== RIGHT LEG (Reverse Knee) ======== -->
      <body name="r_hip_yaw_link" pos="0 -0.1 0">
        <joint name="r_hip_yaw" type="hinge" axis="0 0 1" range="-45 45" damping="2.0"/>
        <geom type="sphere" size="0.04" material="joint_mat"/>

        <body name="r_hip_roll_link" pos="0 0 0">
          <joint name="r_hip_roll" type="hinge" axis="1 0 0" range="-30 30" damping="2.0"/>
          <geom type="sphere" size="0.035" material="joint_mat"/>

          <body name="r_hip_pitch_link" pos="0 0 0">
            <joint name="r_hip_pitch" type="hinge" axis="0 1 0" range="-60 60" damping="2.0"/>
            <geom type="sphere" size="0.035" material="joint_mat"/>

            <!-- Upper leg — heavier (mass concentrated proximally) -->
            <body name="r_thigh" pos="0 0 -0.02">
              <geom name="r_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.3"
                    size="0.045" mass="3.8" material="body_mat"/>

              <!-- REVERSE KNEE: bends BACKWARD (positive range = extension behind)
                   NO actuator — spring provides passive return + locking at extension
                   stiffness models tensegrity self-recovery (0.8s per paper) -->
              <body name="r_knee_link" pos="0 0 -0.3">
                <joint name="r_knee" type="hinge" axis="0 1 0"
                       range="0 120"
                       damping="1.0"
                       stiffness="40"
                       springref="5"/>
                <!-- springref=5: slight bend at rest, spring pushes toward extension
                     stiffness=40: models tensegrity unit's self-recovery force
                     This is the tensegrity knee analog — no motor needed -->
                <geom type="sphere" size="0.035" material="spring_mat"/>

                <!-- Lower leg — lighter (distal mass reduced, ostrich-like) -->
                <body name="r_shin" pos="0 0 -0.02">
                  <geom name="r_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.28"
                        size="0.03" mass="1.2" material="body_mat"/>

                  <!-- ANKLE (single DOF — simplified for reverse knee config) -->
                  <body name="r_ankle_link" pos="0 0 -0.28">
                    <joint name="r_ankle_pitch" type="hinge" axis="0 1 0" range="-45 45"
                           damping="1.0"/>
                    <geom type="sphere" size="0.03" material="joint_mat"/>

                    <!-- Digitigrade foot (toe-standing, like ostrich/horse) -->
                    <body name="r_foot" pos="0.02 0 -0.02">
                      <geom name="r_foot_geom" type="capsule" fromto="0 0 0 0.06 0 -0.03"
                            size="0.025" mass="0.3" material="foot_mat"/>

                      <!-- TOE with Series Elastic Actuator (spring for energy storage)
                           This models the TMP joint from Rubenson 2011
                           Stores 120% more elastic energy than rigid foot -->
                      <body name="r_toe" pos="0.06 0 -0.03">
                        <joint name="r_toe_joint" type="hinge" axis="0 1 0"
                               range="-30 60"
                               stiffness="25"
                               springref="0"
                               damping="0.3"/>
                        <geom name="r_toe_geom" type="capsule" fromto="0 0 0 0.04 0 -0.005"
                              size="0.02" mass="0.15" material="spring_mat"/>
                        <site name="r_toe_tip" pos="0.04 0 -0.005" size="0.01"/>
                      </body>

                      <site name="r_heel" pos="-0.02 0 -0.015" size="0.01"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>

      <!-- ======== LEFT LEG (mirror of right) ======== -->
      <body name="l_hip_yaw_link" pos="0 0.1 0">
        <joint name="l_hip_yaw" type="hinge" axis="0 0 1" range="-45 45" damping="2.0"/>
        <geom type="sphere" size="0.04" material="joint_mat"/>

        <body name="l_hip_roll_link" pos="0 0 0">
          <joint name="l_hip_roll" type="hinge" axis="1 0 0" range="-30 30" damping="2.0"/>
          <geom type="sphere" size="0.035" material="joint_mat"/>

          <body name="l_hip_pitch_link" pos="0 0 0">
            <joint name="l_hip_pitch" type="hinge" axis="0 1 0" range="-60 60" damping="2.0"/>
            <geom type="sphere" size="0.035" material="joint_mat"/>

            <body name="l_thigh" pos="0 0 -0.02">
              <geom name="l_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.3"
                    size="0.045" mass="3.8" material="body_mat"/>

              <body name="l_knee_link" pos="0 0 -0.3">
                <joint name="l_knee" type="hinge" axis="0 1 0"
                       range="0 120"
                       damping="1.0"
                       stiffness="40"
                       springref="5"/>
                <geom type="sphere" size="0.035" material="spring_mat"/>

                <body name="l_shin" pos="0 0 -0.02">
                  <geom name="l_shin_geom" type="capsule" fromto="0 0 0 0 0 -0.28"
                        size="0.03" mass="1.2" material="body_mat"/>

                  <body name="l_ankle_link" pos="0 0 -0.28">
                    <joint name="l_ankle_pitch" type="hinge" axis="0 1 0" range="-45 45"
                           damping="1.0"/>
                    <geom type="sphere" size="0.03" material="joint_mat"/>

                    <body name="l_foot" pos="0.02 0 -0.02">
                      <geom name="l_foot_geom" type="capsule" fromto="0 0 0 0.06 0 -0.03"
                            size="0.025" mass="0.3" material="foot_mat"/>

                      <body name="l_toe" pos="0.06 0 -0.03">
                        <joint name="l_toe_joint" type="hinge" axis="0 1 0"
                               range="-30 60"
                               stiffness="25"
                               springref="0"
                               damping="0.3"/>
                        <geom name="l_toe_geom" type="capsule" fromto="0 0 0 0.04 0 -0.005"
                              size="0.02" mass="0.15" material="spring_mat"/>
                        <site name="l_toe_tip" pos="0.04 0 -0.005" size="0.01"/>
                      </body>

                      <site name="l_heel" pos="-0.02 0 -0.015" size="0.01"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- ======== ACTUATORS (10 total: 5 per leg — NO knee motor!) ======== -->
  <actuator>
    <!-- Right leg (NO r_knee actuator) -->
    <motor name="r_hip_yaw_act"     joint="r_hip_yaw"      gear="80"  ctrlrange="-1 1"/>
    <motor name="r_hip_roll_act"    joint="r_hip_roll"     gear="80"  ctrlrange="-1 1"/>
    <motor name="r_hip_pitch_act"   joint="r_hip_pitch"    gear="120" ctrlrange="-1 1"/>
    <motor name="r_ankle_pitch_act" joint="r_ankle_pitch"  gear="60"  ctrlrange="-1 1"/>
    <motor name="r_toe_act"         joint="r_toe_joint"    gear="30"  ctrlrange="-1 1"/>
    <!-- Left leg (NO l_knee actuator) -->
    <motor name="l_hip_yaw_act"     joint="l_hip_yaw"      gear="80"  ctrlrange="-1 1"/>
    <motor name="l_hip_roll_act"    joint="l_hip_roll"     gear="80"  ctrlrange="-1 1"/>
    <motor name="l_hip_pitch_act"   joint="l_hip_pitch"    gear="120" ctrlrange="-1 1"/>
    <motor name="l_ankle_pitch_act" joint="l_ankle_pitch"  gear="60"  ctrlrange="-1 1"/>
    <motor name="l_toe_act"         joint="l_toe_joint"    gear="30"  ctrlrange="-1 1"/>
  </actuator>

  <sensor>
    <accelerometer name="imu_acc" site="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
    <framequat name="torso_quat" objtype="site" objname="imu_site"/>
    <touch name="r_heel_touch" site="r_heel"/>
    <touch name="r_toe_touch" site="r_toe_tip"/>
    <touch name="l_heel_touch" site="l_heel"/>
    <touch name="l_toe_touch" site="l_toe_tip"/>
  </sensor>
</mujoco>
